      "targetTablePlaceholder": "Empty = LOG_{log_type} default",
      "tooltip": {
        "dataDir": "Directory where Vector stores internal data such as disk buffers and checkpoints. The folder is auto-created if it doesn't exist.",
        "apiIp": "Binding IP for Vector's own status/health API. The dashboard uses this to check Vector status. 0.0.0.0 allows access from all networks.",
        "apiPort": "Port for Vector's status API. Default: 8687 (Agents use 8686). The dashboard 'Infrastructure' panel queries this port to check Vector's status.",
        "listenIp": "IP address to listen for incoming logs from Agent (equipment) PCs. 0.0.0.0 allows connections from all networks — required since Agents connect externally.",
        "listenPort": "Port for receiving Agent logs. Must match the address port in Agent configs. E.g., Agent sends to 'serverIP:6000' → this listens on 6000.",
        "rawPath": "Path pattern for saving raw log files. Supports variables: {{ equipment_type }}, {{ equipment_id }}, {{ filename }}, and date variables %Y (year), %m (month), %d (day).",
        "rawBufSize": "Max disk buffer size for raw file storage. When full, reception pauses to prevent data loss. Set according to available disk space.",
        "apiUri": "Endpoint URL of the Node.js API server (Fastify) that receives parsed log data and stores it in Oracle DB. Default: http://127.0.0.1:3100/api/logs",
        "batchMax": "Max events to batch before sending. Sends immediately when this count is reached. Higher values improve efficiency but may increase latency.",
        "batchTimeout": "Max seconds to wait before sending a partial batch. Prevents data delay. E.g., set to 5 = guaranteed delivery within 5 seconds.",
        "apiBufSize": "Max disk buffer size for API transmission. If the Node.js server is down, data is retained in this buffer and auto-resent on recovery.",
        "retryInitial": "Seconds to wait before the first retry after a failed API transmission. Each subsequent retry waits longer (exponential backoff).",
        "retryMax": "Maximum retry interval in seconds. Even with exponential backoff, the wait time won't exceed this value. E.g., 30 = retries at most every 30s."
      }
    }
  },
