{
  "name": "vector-agent-manager",
  "version": "1.0.0",
  "description": "Vector Agent local monitoring UI for equipment PCs",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build:css": "npx tailwindcss -i src/tailwind-input.css -o public/tailwind.css --minify",
    "build": "npm run build:css && tsc",
    "build:exe": "npm run build:css && node build-exe.mjs",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/static": "^8.0.0",
    "adm-zip": "^0.5.16",
    "dotenv": "^16.4.0",
    "fastify": "^5.2.0",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^22.0.0",
    "@yao-pkg/pkg": "^6.14.1",
    "esbuild": "^0.27.3",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
