# Server
PORT=3110
HOST=0.0.0.0
NODE_ENV=development

# Oracle DB
ORACLE_USER=log_collector
ORACLE_PASSWORD=your_password
ORACLE_CONNECT_STRING=localhost:1521/ORCL
ORACLE_POOL_MIN=4
ORACLE_POOL_MAX=20

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Raw Log Storage
RAW_LOG_BASE_PATH=C:\\data\\raw-logs

# BullMQ
QUEUE_CONCURRENCY=5
BATCH_SIZE=100
BATCH_TIMEOUT_MS=5000

# Heartbeat
HEARTBEAT_TTL_SECONDS=60
