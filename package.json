{
  "name": "vector-log-collector",
  "version": "1.0.0",
  "description": "Distributed Multi-Table Log Collection System",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,magenta \"tsx watch src/index.ts\" \"npm run dev --prefix frontend\"",
    "dev:backend": "tsx watch src/index.ts",
    "dev:frontend": "npm run dev --prefix frontend",
    "build": "tsc",
    "build:frontend": "npm run build --prefix frontend",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "bullmq": "^5.0.0",
    "dotenv": "^16.4.0",
    "fastify": "^5.2.0",
    "ioredis": "^5.4.0",
    "oracledb": "^6.7.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "concurrently": "^9.2.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
